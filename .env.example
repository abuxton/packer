# .env.example
#
# Copy this file to .env and fill in your values.
# .env is git-ignored; .env.example is committed as documentation only.
#
# Packer reads PKR_VAR_<name> environment variables automatically and maps them
# to HCL input variables of the same name, so you can source this file instead
# of passing every -var flag on the command line:
#
#   cp .env.example .env   # then edit .env
#   source .env
#   packer build tfe-local-mirror-gcp
#
# Sections:
#   1. HCP Packer registry
#   2. Packer (shared / debug)
#   3. GCP  — gcp-ubuntu, ubuntu-docker-mirror, ubuntu-docker-local-container, tfe-local-mirror-gcp
#   4. AWS  — tfe-local-mirror-aws
#   5. Azure — tfe-local-mirror-azure
#   6. VMware vSphere — tfe-local-mirror-vmware
#   7. TFE builds (all tfe-local-mirror-* templates)

# =============================================================================
# 1. HCP PACKER REGISTRY
#    Enables build metadata push to the HCP Packer registry.
#    Obtain credentials from HCP Portal → Service Principals.
#    https://developer.hashicorp.com/hcp/docs/hcp/admin/iam/service-principals
# =============================================================================

HCP_CLIENT_ID=<hcp-service-principal-client-id>
HCP_CLIENT_SECRET=<hcp-service-principal-client-secret>

# HCP organisation and project that own the Packer registry bucket.
HCP_ORGANIZATION_ID=<hcp-organization-id>
HCP_PROJECT_ID=<hcp-project-id>

# =============================================================================
# 2. PACKER — SHARED / DEBUG
#    These apply to every build regardless of cloud provider.
#    https://developer.hashicorp.com/packer/docs/commands#environment-variables
# =============================================================================

# Set to 1 to enable verbose Packer logging.
# PACKER_LOG=1

# Write log output to a file instead of (or in addition to) stdout.
# PACKER_LOG_PATH=/tmp/packer.log

# =============================================================================
# 3. GCP
#    Used by: gcp-ubuntu  ubuntu-docker-mirror  ubuntu-docker-local-container
#             tfe-local-mirror-gcp
#
#    Authentication options (choose one):
#      a) Interactive:  gcloud auth application-default login
#      b) Service account key file: set GOOGLE_APPLICATION_CREDENTIALS
#      c) Access token: set GOOGLE_OAUTH_ACCESS_TOKEN
#
#    Required IAM roles: roles/compute.instanceAdmin.v1
#                        roles/iam.serviceAccountUser  (if build VM uses a SA)
# =============================================================================

# Path to a GCP service account JSON key file.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Short-lived access token (e.g. output of `gcloud auth print-access-token`).
# GOOGLE_OAUTH_ACCESS_TOKEN=

# GCP project where build instances run and images are stored.
PKR_VAR_project_id=<your-gcp-project-id>

# GCP zone for the build instance (default: us-central1-a).
PKR_VAR_zone=us-central1-a

# GCE machine type.  e2-standard-2 is sufficient for base images;
# e2-standard-4 is recommended for TFE builds.
PKR_VAR_machine_type=e2-standard-2

# =============================================================================
# 4. AWS
#    Used by: tfe-local-mirror-aws
#
#    Authentication: any standard AWS credential chain is supported.
#    Set static keys below, or use an IAM instance profile / SSO session.
#    https://developer.hashicorp.com/packer/integrations/hashicorp/amazon
# =============================================================================

AWS_ACCESS_KEY_ID=<aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<aws-secret-access-key>
# AWS_SESSION_TOKEN=<aws-session-token>   # required when using temporary credentials

# AWS region where the build runs and the AMI is registered.
# Also exposed as PKR_VAR_region so the Packer variable is populated automatically.
AWS_DEFAULT_REGION=us-east-1
PKR_VAR_region=us-east-1

# EC2 instance type for the build.  m5.xlarge (4 vCPU / 16 GB) is recommended
# for pulling and caching the TFE image layers.
PKR_VAR_instance_type=m5.xlarge

# =============================================================================
# 5. AZURE
#    Used by: tfe-local-mirror-azure
#
#    Authentication: set ARM_* variables for service-principal auth, or run
#    `az login && az account set --subscription <id>` for interactive auth.
#    https://developer.hashicorp.com/packer/integrations/hashicorp/azure
# =============================================================================

# Service-principal credentials (required for non-interactive / CI builds).
ARM_CLIENT_ID=<azure-service-principal-app-id>
ARM_CLIENT_SECRET=<azure-service-principal-password>
ARM_TENANT_ID=<azure-tenant-id>
ARM_SUBSCRIPTION_ID=<azure-subscription-id>

# Also exposed as PKR_VAR_subscription_id so the Packer HCL variable is set.
PKR_VAR_subscription_id=<azure-subscription-id>

# Existing resource group where the managed image will be stored.
PKR_VAR_resource_group=<azure-resource-group-name>

# Azure region for the build VM and output image (default: eastus).
PKR_VAR_location=eastus

# Azure VM size for the build.  Standard_D4s_v3 (4 vCPU / 16 GB) recommended.
PKR_VAR_vm_size=Standard_D4s_v3

# =============================================================================
# 6. VMWARE VSPHERE
#    Used by: tfe-local-mirror-vmware
#
#    All credentials are passed as Packer variables (PKR_VAR_*).
#    PKR_VAR_vcenter_password and PKR_VAR_ssh_password are declared
#    sensitive = true in the template and will not appear in Packer output.
#    https://developer.hashicorp.com/packer/integrations/hashicorp/vsphere
# =============================================================================

# vCenter Server hostname or IP.
PKR_VAR_vcenter_server=vcenter.example.com

# vCenter credentials.
PKR_VAR_vcenter_username=administrator@vsphere.local
PKR_VAR_vcenter_password=<vcenter-password>

# Set to true to allow self-signed TLS certificates (useful in lab environments).
# PKR_VAR_insecure_connection=false

# vSphere placement — datacenter is optional when only one datacenter exists.
# PKR_VAR_datacenter=
PKR_VAR_cluster=<vsphere-cluster-or-esxi-host>
PKR_VAR_datastore=<vsphere-datastore>
PKR_VAR_network=<vsphere-port-group>
# PKR_VAR_folder=

# Build VM hardware (defaults match the variables.pkr.hcl declarations).
# PKR_VAR_cpus=4
# PKR_VAR_ram_mb=16384

# ISO location.  Use a datastore path to avoid a large download:
#   PKR_VAR_iso_url=[DatastoreName] ISOs/ubuntu-24.04.4-live-server-amd64.iso
#   PKR_VAR_iso_checksum=sha256:e907d92eeec9df64163a7e454cbc8d7755e8ddc7ed42f99dbc80c40f1a138433
# PKR_VAR_iso_url=https://releases.ubuntu.com/24.04/ubuntu-24.04.4-live-server-amd64.iso
# PKR_VAR_iso_checksum=file:https://releases.ubuntu.com/24.04/SHA256SUMS

# Build-user password (sensitive, locked on the resulting template).
# PKR_VAR_ssh_password=packer

# =============================================================================
# 7. TFE BUILDS — all tfe-local-mirror-* templates
#    These variables are shared across the GCP, AWS, Azure, and VMware builds.
# =============================================================================

# Terraform Enterprise image tag.
# Find valid tags at: https://developer.hashicorp.com/terraform/enterprise/releases
PKR_VAR_tfe_version=1.2.1

# Path to your TFE license file (.hclic).
# Place the file at <template-dir>/files/terraform.hclic (git-ignored) or
# set an absolute path here.
# NEVER commit .hclic files to source control.
PKR_VAR_tfe_license_file=./files/terraform.hclic
